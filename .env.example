# LLM Provider Configuration
# Primary provider: gemini or openai (default: gemini)
LLM_PROVIDER=gemini

# Google Gemini API Configuration (Primary)
# Get from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI API Configuration (Fallback)
# Get from https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Optional: LLM model to use
# For Gemini: gemini-2.5-flash (default), gemini-2.0-flash, etc.
# For OpenAI: gpt-3.5-turbo (default), gpt-4, etc.
LLM_MODEL=gemini-2.5-flash

# Optional: Temperature for response generation (0.0-2.0, default: 0.7)
LLM_TEMPERATURE=0.7

# Optional: API request timeout in seconds (default: 30)
LLM_TIMEOUT=30

# Optional: Logging level (DEBUG, INFO, WARNING, ERROR, default: INFO)
LOG_LEVEL=INFO
